# ── Required ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# ── Optional ──────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# On Railway / Fly.io set this to the mounted volume path, e.g. /data/bot_data.db
DB_PATH=bot_data.db

# Webhook mode (leave blank to use polling instead)
USE_WEBHOOK=
WEBHOOK_URL=https://your-app.railway.app   # must be HTTPS, no trailing slash
PORT=8080
